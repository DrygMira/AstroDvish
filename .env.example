APP_NAME=astro-ephemeris-service
APP_HOST=0.0.0.0
APP_PORT=8013
APP_LOG_LEVEL=INFO
WEB_UI_HOST=0.0.0.0
WEB_UI_PORT=8014
DOCKER_COMPOSE_API_BASE_URL=http://astrodvish-api:8013
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_GENERATE=gpt-5.4-mini
OPENAI_MODEL_STAGE1=gpt-5.4-mini
OPENAI_MODEL_PRO=gpt-5.4-mini
OPENAI_MAX_TOKENS_DEFAULT=6000
OPENAI_MAX_TOKENS_STAGE1=3000
OPENAI_MAX_TOKENS_GENERATE=8000
OPENAI_MAX_TOKENS_PRO=12000
OPENAI_MAX_TOKENS_HARD_LIMIT=20000
OPENAI_TIMEOUT_SECONDS=120

# Optional OpenRouter fallback mode (used only if LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_BACKUP_1=
OPENROUTER_API_KEY_BACKUP_2=
OPENROUTER_MODEL=openai/gpt-5.4-mini
OPENROUTER_MODEL_RECTIFICATION=openai/gpt-5.4-mini
OPENROUTER_MODEL_HOROSCOPE=openai/gpt-5.4-mini
LLM_MODEL_GENERATE_PRIMARY=openai/gpt-5.4-mini
LLM_MODEL_GENERATE_FALLBACK=openai/gpt-4.1-mini
LLM_MODEL_STAGE1_PRIMARY=openai/gpt-5.4-mini
LLM_MODEL_STAGE1_FALLBACK=openai/gpt-4.1-mini
LLM_MODEL_PRO_PRIMARY=openai/gpt-5.4-mini
LLM_MODEL_PRO_FALLBACK=openai/gpt-4.1-mini
MAX_LLM_ATTEMPTS=4
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://your-site.example
OPENROUTER_APP_NAME=AstroDvish
OPENROUTER_TIMEOUT_SECONDS=120
OPENROUTER_MAX_TOKENS_DEFAULT=6000
OPENROUTER_MAX_TOKENS_STAGE1=2000
OPENROUTER_MAX_TOKENS_GENERATE=8000
OPENROUTER_MAX_TOKENS_PRO=12000
OPENROUTER_MAX_TOKENS_HARD_LIMIT=20000
SWEPH_EPHE_PATH=/opt/ephe
SWEPH_AUTO_DOWNLOAD=true
SWEPH_DOWNLOAD_TIMEOUT=120
SWEPH_DOWNLOAD_RETRIES=2
SWEPH_DOWNLOAD_BASE_URLS=https://www.astro.com/ftp/swisseph/ephe,https://github.com/aloistr/swisseph/raw/master/ephe
